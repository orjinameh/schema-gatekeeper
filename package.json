{
  "name": "schema-gatekeeper",
  "version": "1.0.0",
  "description": "On-Demand Schema Gatekeeper — MCP proxy that strips tool bloat",
  "bin": {
    "schema-gatekeeper": "src/index.ts"
  },
  "scripts": {
    "start": "node --import tsx/esm src/index.ts",
    "dev": "node --import tsx/esm src/index.ts",
    "test": "node --import tsx/esm src/test.ts",
    "benchmark": "node --import tsx/esm src/benchmark.ts",
    "eval": "node --import tsx/esm src/eval.ts",
    "eval:agent": "node --import tsx/esm src/agent-eval.ts",
    "demo": "node --import tsx/esm src/server.ts",
    "setup:datahub": "docker compose -f ~/.datahub/quickstart/docker-compose.yml -p datahub up -d && sleep 30 && docker start datahub-datahub-actions-quickstart-1 datahub-frontend-quickstart-1 2>/dev/null; echo 'DataHub starting on http://localhost:8080'"
  },
  "keywords": [
    "mcp",
    "llm",
    "proxy",
    "schema"
  ],
  "author": "",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.112.4",
    "@google/genai": "^2.13.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@modelcontextprotocol/server-filesystem": "^2026.7.10",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.9.3"
  }
}
